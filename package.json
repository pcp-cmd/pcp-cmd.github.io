{
  "name": "aleksi-lab-site",
  "version": "1.7.2",
  "private": true,
  "scripts": {
    "dev": "node server.js",
    "import:skill": "node scripts/import-skill.js",
    "import:math": "node scripts/import-math-chapter.js",
    "build:markdown": "node scripts/build-markdown.js",
    "build:content": "node scripts/build-content-manifest.js && node scripts/build-content-bundle.js",
    "build": "npm run build:markdown && npm run build:content",
    "build:local": "npm run import:skill && npm run import:math && npm run build",
    "qa": "node qa-check.js",
    "qa:browser": "node scripts/browser-qa.js",
    "verify": "npm run qa && npm run build && npm run qa:browser",
    "build:bundle": "node scripts/build-content-bundle.js"
  }
}
